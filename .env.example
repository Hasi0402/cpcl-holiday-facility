# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cpcl_holiday
DB_USER=postgres
DB_PASSWORD=change_this_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=8h

# ─── Email (SMTP via Nodemailer) ──────────────────────────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM="CPCL Holiday Facility <noreply@cpcl.co.in>"
IT_ADMIN_EMAIL=itadmin@cpcl.co.in
FINANCE_EMAIL=finance@cpcl.co.in

# ─── Frontend (comma-separate multiple origins) ───────────────────────────────
FRONTEND_URL=http://localhost:5500
