{
  "info": {
    "name": "CPCL Holiday Facility API",
    "description": "Full endpoint collection for Phases 1-7. Set {{baseUrl}} and run 'Login' first to auto-populate {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "financeToken", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "hotelId", "value": "1" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login - Employee",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('token', json.token);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": \"EMP001\",\n  \"password\": \"pass\"\n}" }
          }
        },
        {
          "name": "Login - IT Admin",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('adminToken', json.token);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": \"ADMIN01\",\n  \"password\": \"admin\"\n}" }
          }
        },
        {
          "name": "Login - Finance",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('financeToken', json.token);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": \"FIN01\",\n  \"password\": \"fin\"\n}" }
          }
        },
        {
          "name": "Login - Invalid Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": \"EMP001\",\n  \"password\": \"wrongpass\"\n}" }
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "2. Hotels",
      "item": [
        {
          "name": "List All Hotels",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/hotels"
          }
        },
        {
          "name": "Get Hotel by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/hotels/{{hotelId}}"
          }
        }
      ]
    },
    {
      "name": "3. Bookings (Employee)",
      "item": [
        {
          "name": "Get Quota Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/bookings/quota/status"
          }
        },
        {
          "name": "Create Booking",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const json = pm.response.json();",
              "if (json.booking) pm.collectionVariables.set('bookingId', json.booking.id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hotelId\": 1,\n  \"hotelRef\": \"REF-2026-001\",\n  \"checkIn\": \"2026-08-10\",\n  \"nights\": 3,\n  \"numAdults\": 4,\n  \"numChildren\": 1,\n  \"numRooms\": 2,\n  \"purpose\": \"Family vacation, extra bed requested\"\n}"
            }
          }
        },
        {
          "name": "Create Booking - Duplicate (should 409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hotelId\": 2,\n  \"hotelRef\": \"REF-2026-002\",\n  \"checkIn\": \"2026-09-01\",\n  \"nights\": 2,\n  \"numAdults\": 2,\n  \"numChildren\": 0,\n  \"numRooms\": 1\n}"
            }
          }
        },
        {
          "name": "Create Booking - Invalid (6 adults, should 400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hotelId\": 1,\n  \"hotelRef\": \"REF-X\",\n  \"checkIn\": \"2026-08-10\",\n  \"nights\": 2,\n  \"numAdults\": 6,\n  \"numChildren\": 0,\n  \"numRooms\": 1\n}"
            }
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/bookings/my"
          }
        },
        {
          "name": "Get Booking by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Cancellation Preview",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/bookings/{{bookingId}}/cancellation-preview"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/bookings/{{bookingId}}/cancel",
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Cancel Booking - Fee Exempt (CPRC rejection)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/bookings/{{bookingId}}/cancel",
            "body": { "mode": "raw", "raw": "{\n  \"reasonCode\": \"cprc_rejection\"\n}" }
          }
        }
      ]
    },
    {
      "name": "4. Admin (IT)",
      "item": [
        {
          "name": "Get Pending Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/bookings/pending"
          }
        },
        {
          "name": "Get All Bookings (filtered)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/bookings?status=Approved"
          }
        },
        {
          "name": "Approve Booking",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/bookings/{{bookingId}}/approve"
          }
        },
        {
          "name": "Reject Booking",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/bookings/{{bookingId}}/reject",
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Hotel fully booked for requested dates\"\n}" }
          }
        },
        {
          "name": "Approve Booking - As Employee (should 403)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/bookings/{{bookingId}}/approve"
          }
        }
      ]
    },
    {
      "name": "5. Finance",
      "item": [
        {
          "name": "Get Cancellations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{financeToken}}" }],
            "url": "{{baseUrl}}/finance/cancellations"
          }
        },
        {
          "name": "Get Reports",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{financeToken}}" }],
            "url": "{{baseUrl}}/finance/reports"
          }
        }
      ]
    },
    {
      "name": "6. Health",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        }
      ]
    }
  ]
}
